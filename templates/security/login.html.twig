{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}

    <div class="flex flex-wrap flex-grow bg-[#FFFDF7] overflow-hidden">
        <div class="flex flex-wrap flex-grow">

            <div class="hidden lg:block lg:w-1/2 relative">
                <img src="{{ asset('img/login_img.jpg') }}" class="absolute inset-0 w-full h-full object-cover" alt="Image de connexion">
                <!-- Overlay optionnel pour adoucir l'image -->
                <div class="absolute inset-0 bg-black opacity-10"></div>
            </div>

            <!-- Colonne Formulaire (Gauche) -->
            <div class="w-full lg:w-1/2 flex justify-center px-6 lg:px-0">
                <div class="w-3/4 py-12 lg:py-24">

                    <form method="post" class="space-y-6">
                        <h1 class="text-xl text-gray-900 mb-8">Connexion</h1>

                        {# Gestion des erreurs de sécurité #}
                        {% if error %}
                            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg shadow-sm mb-6">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <!-- Champ Email -->
                        <div class="flex flex-col space-y-2">
                            <label for="username" class="text-sm text-[#666666]">Adresse email</label>
                            <input type="email" value="{{ last_username }}" name="_username" id="username"
                                class="w-full p-3 border border-gray-300 bg-transparent outline-none transition-all"
                                autocomplete="email" required autofocus>
                        </div>

                        <!-- Champ Mot de passe -->
                        <div class="flex flex-col space-y-2">
                            <label for="password" class="text-sm text-[#666666]">Mot de passe</label>
                            <input type="password" name="_password" id="password"
                                class="w-full p-3 border border-gray-300 bg-transparent outline-none transition-all"
                                autocomplete="current-password" required>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        {# Section Remember Me (Optionnelle) #}
                        {#
                        <div class="flex items-center">
                            <input type="checkbox" name="_remember_me" id="_remember_me" class="h-4 w-4 text-primary border-gray-300 rounded focus:ring-primary">
                            <label for="_remember_me" class="ml-2 block text-sm text-gray-700">Se souvenir de moi</label>
                        </div>
                        #}

                        <!-- Bouton Submit -->
                        <button type="submit"
                                class="w-full bg-[#565656] text-white font-bold py-6">
                            Se connecter
                        </button>

                    </form>

                    <a class="text-[#666666] text-sm underline mt-6 flex justify-center" href="{{ path('app_register') }}">Pas encore de compte ? S'inscrire</a>

                </div>
            </div>

        </div>
    </div>



{% endblock %}

