{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="w-full min-h-screen w-screen overflow-hidden">
    <div class="w-full bg-gray-50 flex flex-col ">
        <div class="flex flex-wrap flex-grow h-[750px] max-h-[750px] overflow-hidden border-b border-gray-100">

            <!-- Colonne Texte -->
            <div class="w-full lg:w-1/2 flex items-center justify-center px-6 lg:px-0 bg-[#E8F0E3]">
                <div class="flex flex-col w-1/2 space-y-6">
                    <h1 class="text-7xl text-gray-900 leading-tight">
                        Bienvenue
                    </h1>
                    <div class="space-y-4 text-gray-600 text-lg">
                        <p>Découvrez notre univers de produits durables et éthiques pour une consommation responsable.</p>
                        <p>Retrouvez des articles d’hygiène & beauté, des accessoires & boissons et du prêt à porter.</p>
                    </div>
                </div>
            </div>

            <!-- Colonne Image -->
            <div class="hidden lg:block lg:w-1/2 h-full">
                <img src="{{ asset('img/home_img.jpg') }}"
                    class="w-full h-full object-cover shadow-inner"
                    alt="Image d'inscription">
            </div>

        </div>
    </div>
    <div id="products" class="">
        <h2 class="px-4 py-6 text-[14px] font-medium text-gray-900 mx-[50px] uppercase">Nos produits</h2>

        <div class="grid grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
            {% for product in products %}
                <div class="w-full bg-white h-100">
                    <img src="{{ asset('product_img/' ~ product.picture) }}" alt="{{ product.name }}" class="w-full h-[480px] object-cover">
                    <div class="p-4 text-center bg-[#FFFDF7]">
                        <h3 class="text-lg font-semibold text-gray-900 mt-4">{{ product.name }}</h3>
                         <p class="text-gray-500 mb-4">{{ product.shortDescription }}</p>
                        <p class="mb-8">{{ product.price }} €</p>
                        <a href="{{ path('app_product', {id: product.id}) }}" class="text-primary hover:underline">Voir le produit</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    <div>
        <div class="flex flex-wrap flex-grow h-[750px] max-h-[750px] overflow-hidden border-b border-gray-100">

            <div class="w-2/3 p-8 flex flex-col justify-end px-6  bg-[#EBE3D3]">
                <div class="flex flex-col justify-end w-1/2">
                    <h1 class="text-xl w-1/2 text-gray-900 font-semibold leading-tight mb-3">
                        NOTRE CONVICTION
                    </h1>
                    <div class="text-gray-600 text-[14px]">
                        <p>Chez GreenGoodies, nous croyons en un monde où le commerce peut être synonyme de bien-être pour la planète et ses habitants. Notre mission est de vous proposer une sélection rigoureuse de produits qui allient qualité, durabilité et éthique</p>
                    </div>
                </div>
            </div>

            <div class="hidden lg:block w-1/3 h-full">
                <img src="{{ asset('img/login_img.jpg') }}"
                    class="w-full h-full object-cover shadow-inner"
                    alt="Image d'inscription">
            </div>

        </div>
    </div>
    <div>
        <div class="flex flex-wrap flex-grow h-[750px] max-h-[750px] overflow-hidden border-b border-gray-100">

            <div class="hidden lg:block w-1/3 h-full">
                <img src="{{ asset('img/trashbag_img.jpg') }}"
                    class="w-full h-full object-cover shadow-inner"
                    alt="Image d'inscription">
            </div>

            <div class="w-2/3 p-8 flex justify-end px-6 bg-[#E8F0E3]">
                <div class="flex flex-col justify-end w-1/2">
                    <h1 class="text-xl w-1/2 text-gray-900 font-semibold leading-tight mb-3">
                        NOS VALEURS
                    </h1>
                    <div class="text-gray-600 text-[14px]">
                        <p>
                            Durabilité : Nous sélectionnons soigneusement des produits qui respectent l'environnement et favorisent la durabilité.<br>
                            Éthique : Nous nous engageons à travailler avec des partenaires et des fournisseurs qui partagent nos valeurs éthiques.<br>
                            Écologie : Nous encourageons des pratiques respectueuses de l'écosystème et privilégions les matériaux écologiques.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>



</div>
{% endblock %}
