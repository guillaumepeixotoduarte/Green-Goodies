# config dans public/.htaccess

<IfModule mod_expires.c>
    # On active le module d'expiration
    ExpiresActive On

    # On dit au navigateur de garder les images WebP en cache pendant 1 an (en secondes)
    ExpiresByType image/webp "access plus 1 year"

    # Sécurité pour les autres formats s'il en reste
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # On ajoute l'en-tête Cache-Control moderne pour les navigateurs récents
    # "immutable" indique que le fichier ne changera jamais de nom, évitant même la micro-requête de vérification
    <FilesMatch "\.(webp|jpeg|jpg|png|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
